{
  "name": "dev-workflow-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "dev-workflow 플러그인 MCP 서버 — merge-to-domain digest 추출·검증·체크포인트 도구 (머지군 3도구 MVP)",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js",
    "pretest": "esbuild test/digest.test.ts test/verify.test.ts test/checkpoint.test.ts --bundle --platform=node --target=node18 --format=cjs --outdir=test-dist",
    "test": "node --test \"test-dist/*.test.js\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
