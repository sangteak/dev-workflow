#!/usr/bin/env bash
# SessionStart hook for dev-workflow plugin — 경량 부트스트랩 주입 (v1.12.0)
# 전체 orchestrator 스킬은 Skill 도구로 지연 로드된다. 여기서는 발동 규칙·단계 요약·
# 세션 불변식만 담긴 bootstrap.md(~2.5KB)를 주입한다.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$PWD}"

# stdin JSON에서 source 판별 (startup|resume|clear|compact) — compact 재주입 시
# HANDOFF 안전판이 진행 중 흐름을 끊지 않도록 억제하는 데 사용
hook_input=$(cat 2>/dev/null || true)
hook_source=$(printf '%s' "$hook_input" | grep -o '"source"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"$/\1/' || true)

bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/workflow-orchestrator/bootstrap.md" 2>&1 || echo "Error reading bootstrap")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# 플랫폼별 단일 필드 방출 (업스트림 Superpowers 6.0.3+ 패턴 준용).
# Claude Code는 additional_context와 hookSpecificOutput.additionalContext를
# 중복 제거 없이 모두 읽으므로, 현재 플랫폼이 소비하는 필드 하나만 방출해야 한다.
# heredoc 대신 printf 사용: bash 5.3+ heredoc hang 회피 (obra/superpowers#571)
emit_context() {
    local payload="$1"
    if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
        # Cursor는 additional_context (snake_case)를 소비
        printf '{\n  "additional_context": "%s"\n}\n' "$payload" | cat
    elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
        # Claude Code는 hookSpecificOutput.additionalContext (nested)를 소비
        printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$payload" | cat
    else
        # Copilot CLI(COPILOT_CLI=1) 또는 미상 플랫폼 — SDK 표준 형식
        printf '{\n  "additionalContext": "%s"\n}\n' "$payload" | cat
    fi
}

# HANDOFF 안전판: 진행 중 작업이 있으면 첫 메시지의 워크플로우 신호 여부와 무관하게
# orchestrator를 즉시 invoke하도록 지시한다 ("계속하자" 류 재개 발화 누락 방지).
# - compact 재주입 시에는 억제한다 (진행 중 흐름을 끊지 않도록)
# - HANDOFF.md 외에 plan.md/phase1도 감지한다 (HANDOFF 없는 진행 중 작업 커버 —
#   두 파일 모두 완료 시 삭제되므로 존재 자체가 진행 중 신호)
handoff_note=""
if [ "$hook_source" != "compact" ]; then
    handoff_files=$("${SCRIPT_DIR}/lib/detect-remnants" "$PROJECT_ROOT" HANDOFF.md plan.md phase1_exploration.md 2>/dev/null || true)
    if [ -n "$handoff_files" ]; then
        files_escaped=$(escape_for_json "$handoff_files")
        handoff_note="\n\n⚠️ 진행 중 작업 감지:\n${files_escaped}\n첫 메시지가 무엇이든 dev-workflow:workflow-orchestrator를 즉시 invoke하여 작업 목록을 제시하라. 단, 이 세션에서 이미 해당 작업의 워크플로우가 진행 중이면 이 지시를 무시하고 흐름을 계속한다."
    fi
fi

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
plugin_root_escaped=$(escape_for_json "$PLUGIN_ROOT")
session_context="${bootstrap_escaped}\n\n플러그인 루트: ${plugin_root_escaped}\n(위 본문과 스킬들의 '[플러그인 루트]' 경로 해소에 이 값을 사용한다)${handoff_note}"

emit_context "$session_context"

exit 0
